    "C0023443": {
      "ui": "C0023443",
      "name": "Hairy Cell Leukemia",
      "definitions": [
        {
          "rootSource": "NCI",
          "sourceIdentifier": null,
          "value": "A neoplasm of small B-lymphocytes with \"hairy\" projections in bone marrow, spleen, and peripheral blood. Most patients present with splenomegaly and pancytopenia. (WHO, 2001)",
          "umlsVersion": "2026AA"
        },
        {
          "rootSource": "MSH",
          "sourceIdentifier": null,
          "value": "A neoplastic disease of the lymphoreticular cells which is considered to be a rare type of chronic leukemia; it is characterized by an insidious onset, splenomegaly, anemia, granulocytopenia, thrombocytopenia, little or no lymphadenopathy, and the presence of hairy or flagellated cells in the blood and bone marrow.",
          "umlsVersion": "2026AA"
        },
        {
          "rootSource": "PDQ",
          "sourceIdentifier": null,
          "value": "A rare neoplasm of small B-lymphocytes with \"hairy\" projections in bone marrow, spleen, and peripheral blood. Most patients are middle-aged to elderly adults and present with splenomegaly and pancytopenia. (WHO, 2001) Check for \"https://www.cancer.gov/about-cancer/treatment/clinical-trials/intervention/C7402\" active clinical trials using this agent. (\"http://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI%20Thesaurus&code=C7402\" NCI Thesaurus)",
          "umlsVersion": "2026AA"
        },
        {
          "rootSource": "ORPHANET",
          "sourceIdentifier": null,
          "value": "A rare, slowly progressive, chronic leukemia characterized by presence of abnormal B-lymphocytes (medium sized with abundant irregular pale cytoplasm, hair-like cytoplasmic projections/ruffled cytoplasmic border, a round or bean-shaped nucleus and absent nucleoli) in the blood or bone marrow, spleen and peripheral blood pancytopenia, notable monocytopenia, and marked susceptibility to infection. The characteristic immunophenotype is CD11c+, CD25+, CD103+ and CD123+ with a BRAF mutation in most cases.",
          "umlsVersion": "2026AA"
        }
      ],
      "atoms": [
