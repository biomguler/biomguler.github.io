      "name": "Monoclonal B-Cell Lymphocytosis",
      "definitions": [
        {
          "rootSource": "NCI",
          "sourceIdentifier": null,
          "value": "A monoclonal expansion of B-lymphocytes with or without the characteristic immunophenotype of chronic lymphocytic leukemia. It precedes virtually all cases of chronic lymphocytic leukemia/small lymphocytic lymphoma.",
