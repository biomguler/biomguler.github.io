    "C0855095": {
      "ui": "C0855095",
      "name": "Small Lymphocytic Lymphoma",
      "definitions": [
        {
          "rootSource": "NCI",
          "sourceIdentifier": null,
          "value": "A non-Hodgkin lymphoma composed of monomorphic small, round B-lymphocytes in the lymph nodes. When the lymphoid process predominantly involves the bone marrow and the peripheral blood it is called chronic lymphocytic leukemia. (WHO, 2001)",
          "umlsVersion": "2026AA"
        },
        {
          "rootSource": "PDQ",
          "sourceIdentifier": null,
          "value": "A non-Hodgkin lymphoma composed of monomorphic small, round B-lymphocytes in the lymph nodes. When the lymphoid process predominantly involves the bone marrow and the peripheral blood it is called chronic lymphocytic leukemia. (WHO, 2001) Check for \"https://www.cancer.gov/about-cancer/treatment/clinical-trials/intervention/C7540\" active clinical trials using this agent. (\"http://ncit.nci.nih.gov/ncitbrowser/ConceptReport.jsp?dictionary=NCI%20Thesaurus&code=C7540\" NCI Thesaurus)",
          "umlsVersion": "2026AA"
        }
