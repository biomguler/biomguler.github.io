    "C5230690": {
      "ui": "C5230690",
      "name": "Monoclonal B-cell lymphocytosis non-chronic lymphocytic leukemia type",
      "definitions": [
        {
          "rootSource": "NCI",
          "sourceIdentifier": null,
          "value": "Monoclonal B-cell lymphocytosis characterized by the presence of fewer than 5 x 10^9/L abnormal B-lymphocytes in peripheral blood and absence of the characteristic immunophenotype of chronic lymphocytic leukemia. This type of monoclonal B-cell lymphocytosis does not progress to chronic lymphocytic leukemia.",
          "umlsVersion": "2026AA"
